# NewsAPI key — get yours at https://newsapi.org
NEWS_API_KEY=your_key_here

# Anthropic Claude API key (optional) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Set to "true" to enable Claude-powered summaries (requires ANTHROPIC_API_KEY)
SUMMARISE_WITH_AI=false

# How often (in minutes) the background scheduler fetches fresh articles
FETCH_INTERVAL_MINUTES=60

# Port the FastAPI server listens on
PORT=8000
